# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

PORT=3000

# MongoDB (міндетті — авторизация + чаттар)
DATABASE_URL=mongodb://localhost:27017/bayeke
# Atlas мысалы:
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/bayeke

# JWT (production-да күшті кілт қойыңыз)
JWT_SECRET=your_jwt_secret_here
